{
  "name": "acquisition-os-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "dev:safe": "npm run db:generate && npm run build && node dist/index.js",
    "dev:safe:tsx": "npm run db:generate && npx tsx src/index.ts",
    "dev:watch-compile": "tsc --watch --preserveWatchOutput",
    "dev:watch-run": "node --watch dist/index.js",
    "build": "tsc && (test -d src/generated || (echo 'Run npm run db:generate first (missing src/generated).' && exit 1)) && rm -rf dist/generated && cp -R src/generated dist/",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "esbuild": "^0.27.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
