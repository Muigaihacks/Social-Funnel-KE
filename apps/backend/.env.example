# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/acquisition_os?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Webhooks (verification + Meta lead fetch)
META_WEBHOOK_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
LINKEDIN_CLIENT_SECRET=

# n8n event trigger (backend -> n8n after ingest)
N8N_INGEST_WEBHOOK_URL=
N8N_INGEST_WEBHOOK_SECRET=
N8N_INGEST_WEBHOOK_TIMEOUT_MS=4000

# Optional: for 60-second response engine and n8n
OPENAI_API_KEY=
WHATSAPP_360DIALOG_API_KEY=
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=
CALENDLY_WEBHOOK_SECRET=

# Shared secret for n8n → backend (weekly report ingest, workflow heartbeats)
INTERNAL_AUTOMATION_SECRET=
