{
  "name": "acquisition-os",
  "version": "0.1.0",
  "private": true,
  "description": "Social Funnel Lead-to-Booking OS — Internal-first, clonable deployment",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run db:generate -w apps/backend",
    "db:push": "npm run db:push -w apps/backend",
    "db:migrate": "npm run db:migrate -w apps/backend",
    "clean": "rm -rf apps/frontend/.next apps/frontend/out apps/backend/dist",
    "clean:deps": "rm -rf node_modules apps/frontend/node_modules apps/backend/node_modules",
    "clean:all": "npm run clean && npm run clean:deps",
    "reinstall": "bash scripts/reset-dev-environment.sh",
    "doctor": "node scripts/verify-install.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED"
}
